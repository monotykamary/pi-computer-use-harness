{
  "name": "@monotykamary/pi-computer-use",
  "version": "0.3.3",
  "description": "macOS computer-use for Pi via harness server and CLI.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "computer-use",
    "macos",
    "screenshot",
    "automation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monotykamary/pi-computer-use.git"
  },
  "bugs": {
    "url": "https://github.com/monotykamary/pi-computer-use/issues"
  },
  "homepage": "https://github.com/monotykamary/pi-computer-use#readme",
  "engines": {
    "node": ">=20.6.0"
  },
  "files": [
    "extensions",
    "harness",
    "skills",
    "src",
    "scripts/build-native.mjs",
    "scripts/setup-helper.mjs",
    "native/macos/bridge.swift",
    "prebuilt/macos",
    "assets/img.jpg",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "image": "./assets/img.jpg"
  },
  "scripts": {
    "postinstall": "node scripts/setup-helper.mjs --postinstall",
    "lint:dead": "knip --no-gitignore",
    "typecheck": "tsc -p tsconfig.json",
    "build:native": "node scripts/build-native.mjs",
    "benchmark:qa": "npx -y tsx benchmarks/qa.ts --allow-foreground-qa",
    "benchmark:qa:full": "npx -y tsx benchmarks/qa.ts --allow-foreground-qa --allow-screen-takeover",
    "test": "npm run typecheck",
    "test:e2e": "npx tsx harness/e2e.ts",
    "test:e2e:write": "npx tsx harness/e2e.ts --allow-write",
    "test:commits": "node scripts/check-commit-messages.mjs"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "knip": "6.14.1",
    "typescript": "6.0.3"
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "fast-xml-builder": "1.2.0",
    "protobufjs": "8.4.0",
    "ws": "8.20.1"
  },
  "packageManager": "pnpm@11.6.0"
}
