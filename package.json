{
  "name": "@injaneity/pi-computer-use",
  "version": "0.3.0",
  "description": "macOS computer-use for Pi via harness server and CLI.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "computer-use",
    "macos",
    "screenshot",
    "automation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/injaneity/pi-computer-use.git"
  },
  "bugs": {
    "url": "https://github.com/injaneity/pi-computer-use/issues"
  },
  "homepage": "https://github.com/injaneity/pi-computer-use#readme",
  "engines": {
    "node": ">=20.6.0"
  },
  "files": [
    "extensions",
    "harness",
    "skills",
    "src",
    "scripts/build-native.mjs",
    "scripts/setup-helper.mjs",
    "native/macos/bridge.swift",
    "prebuilt/macos",
    "assets/img.jpg",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "image": "./assets/img.jpg"
  },
  "scripts": {
    "postinstall": "node scripts/setup-helper.mjs --postinstall",
    "lint:dead": "knip --no-gitignore",
    "typecheck": "tsc -p tsconfig.json",
    "build:native": "node scripts/build-native.mjs",
    "benchmark:qa": "npx -y tsx benchmarks/qa.ts --allow-foreground-qa",
    "benchmark:qa:full": "npx -y tsx benchmarks/qa.ts --allow-foreground-qa --allow-screen-takeover",
    "test:e2e": "npx tsx harness/e2e.ts",
    "test:e2e:write": "npx tsx harness/e2e.ts --allow-write"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "knip": "^6.7.0",
    "typescript": "^6.0.3"
  }
}
